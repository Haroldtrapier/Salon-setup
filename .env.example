# OpenAI - Required for AI nail measurement + Nova chatbot
OPENAI_API_KEY=sk-...

# Backend API (Railway) - Optional, nail profiles saved here
# If not set, measurements still work but won't be persisted to DB
NEXT_PUBLIC_API_URL=https://your-railway-app.railway.app

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
